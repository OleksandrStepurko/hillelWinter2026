<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog logicalFilePath="db.changelog-1.0.xml"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

<changeSet id="create-tavlr-and-seed-cars" author="olexandr">

    <!-- 1. Create table -->
    <createTable tableName="tavlr">
        <column name="id" type="BIGINT" autoIncrement="true">
            <constraints primaryKey="true" nullable="false"/>
        </column>
        <column name="brand" type="VARCHAR(100)">
            <constraints nullable="false"/>
        </column>
        <column name="model" type="VARCHAR(100)">
            <constraints nullable="false"/>
        </column>
        <column name="year" type="INT"/>
        <column name="price" type="DECIMAL(10,2)"/>
    </createTable>

    <!-- 2. Insert 15 records -->
    <insert tableName="tavlr">
        <column name="brand" value="Toyota"/>
